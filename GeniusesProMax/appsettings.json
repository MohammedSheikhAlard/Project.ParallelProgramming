{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "YourVeryLongSecretKeyThatIsAtLeast32Bytes!",
    "Issuer": "ECommerceApi",
    "Audience": "ECommerceClient",
    "ExpireMinutes": 60
  },
  "Checkout": {
    "MaxConcurrentCheckouts": 10,
    "SemaphoreTimeoutSeconds": 30
  },
    "ConnectionStrings": {
      "DefaultConnection": "...",
      "Redis": "localhost:6379"
    }
}
